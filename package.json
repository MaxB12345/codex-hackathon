{
  "name": "ai-bug-resolution-agent",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api dev:worker",
    "dev:web": "npm run dev --workspace @bug-agent/web",
    "dev:api": "npm run dev --workspace @bug-agent/api",
    "dev:worker": "npm run dev --workspace @bug-agent/worker",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "db:migrate": "tsx packages/db/src/scripts/migrate.ts",
    "db:seed": "tsx packages/db/src/scripts/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
